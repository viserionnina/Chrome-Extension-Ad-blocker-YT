{
    "manifest_version": 3,
    "name":"Ad Blocker for YT",
    "version": "1.1",
    "description": "Siple ad blocker for YouTube.",
    "permissions":[
        "delacrativeNetRequest",
        "activeTab"
    ],
    "host_premission":["*://*.youtube.com/*"],
    "background":{
        "service_worker": "background.js"
    },
    "content_scripts":[
        {
            "matches": ["*://*.youtube.com/*"],
            "js": ["content.js"]
        }
    ]
}